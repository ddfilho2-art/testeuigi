# ============================================================
# Control Med — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- Supabase ---
# URL do projeto Supabase (Configurações > API > Project URL)
SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave de serviço do Supabase (service_role key) — com permissões admin.
# ATENÇÃO: use a service_role key, não a anon key, para operações do servidor.
SUPABASE_KEY="sua-service-role-key"

# --- Admin Dashboard ---
# E-mail e senha de acesso ao painel administrativo.
# Estes valores são usados se a configuração de perfil não estiver salva.
ADMIN_EMAIL="admin@controlseg.com.br"
ADMIN_PASSWORD="troque-por-uma-senha-forte"

# --- (Opcional) ---
# Não é necessário para o deploy no Vercel.
# GEMINI_API_KEY="sua-chave-gemini"
# APP_URL="https://seu-app.vercel.app"
