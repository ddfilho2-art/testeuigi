# ============================================================
# Control Med — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- Supabase ---
# URL do projeto Supabase (Configurações > API > Project URL)
SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave de serviço (service_role) — bypassa RLS, usada para DB/RPC/Storage.
# ATENÇÃO: mantenha em segredo absoluto, nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# Chave anônima (anon) — usada apenas para auth.signInWithPassword / getUser.
# Encontre em: Configurações > API > Project API Keys > "anon public"
SUPABASE_ANON_KEY="sua-anon-key"

# (Legado) Se você só tiver uma chave definida, SUPABASE_KEY é usada como
# fallback para ambos os clientes. Preferível definir as duas acima.
# SUPABASE_KEY="sua-chave"

# --- JWT (tokens de admin e de download de PDF) ---
# Segredo usado para assinar os JWTs. OBRIGATÓRIO em produção (>= 16 chars).
# Gere um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-aleatorio-de-no-minimo-16-caracteres"

# Validade do token de admin (ex.: 8h, 12h, 1d). Padrão: 8h.
JWT_EXPIRES_IN="8h"

# Validade do token de download de PDF emitido no submit (padrão: 30m).
PDF_TOKEN_EXPIRES_IN="30m"

# --- Admin Dashboard (credenciais locais fallback) ---
# Usadas quando o perfil admin ainda não foi salvo no email_config.json.
ADMIN_EMAIL="admin@controlseg.com.br"
ADMIN_PASSWORD="troque-por-uma-senha-forte"

# --- SMTP (opcional via painel admin; aqui só como fallback) ---
# Os campos SMTP também podem ser configurados pelo painel administrativo,
# que os persiste em email_config.json. As vars abaixo são defaults opcionais.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_SECURE="false"

# --- Servidor ---
# Porta do servidor de desenvolvimento (padrão: 3000).
# PORT=3000

# --- (Opcional) ---
# GEMINI_API_KEY="sua-chave-gemini"
# APP_URL="https://seu-app.vercel.app"
